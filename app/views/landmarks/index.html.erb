<h1>All Landmarks</h1>

<div class="row mb-4">
  <div class="col">
    <%= link_to "Back to Home", root_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="row">
  <% @landmarks.each do |landmark| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title"><%= landmark.name %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= landmark.category %></h6>
          <p class="card-text">
            <strong>Address:</strong> <%= landmark.address.truncate(50) %><br>
            <strong>Reviews:</strong> <%= landmark.reviews.count %>
          </p>
        </div>
        <div class="card-footer">
          <%= link_to "View Details", landmark_path(landmark), class: "btn btn-success btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
