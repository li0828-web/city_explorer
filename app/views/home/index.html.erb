<div class="jumbotron">
  <h1>Welcome to CityExplorer</h1>
  <p>Discover amazing restaurants and landmarks in your city!</p>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h3>Recent Restaurants</h3>
      </div>
      <div class="card-body">
        <ul class="list-group">
          <% Restaurant.last(5).each do |restaurant| %>
            <li class="list-group-item">
              <%= link_to restaurant.name, restaurant_path(restaurant) %>
              <span class="badge bg-primary float-end"><%= restaurant.cuisine %></span>
            </li>
          <% end %>
        </ul>
        <%= link_to "View All Restaurants", restaurants_path, class: "btn btn-primary mt-3" %>
      </div>
    </div>
  </div>
  
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h3>Recent Landmarks</h3>
      </div>
      <div class="card-body">
        <ul class="list-group">
          <% Landmark.last(5).each do |landmark| %>
            <li class="list-group-item">
              <%= link_to landmark.name, landmark_path(landmark) %>
              <span class="badge bg-success float-end"><%= landmark.category %></span>
            </li>
          <% end %>
        </ul>
        <%= link_to "View All Landmarks", landmarks_path, class: "btn btn-success mt-3" %>
      </div>
    </div>
  </div>
</div>

<div class="row mt-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3>Recent Reviews</h3>
      </div>
      <div class="card-body">
        <% Review.last(5).each do |review| %>
          <div class="mb-3">
            <strong><%= review.user_name %></strong> rated 
            <% if review.reviewable_type == "Restaurant" %>
              <%= link_to review.reviewable.name, restaurant_path(review.reviewable) %>
            <% else %>
              <%= link_to review.reviewable.name, landmark_path(review.reviewable) %>
            <% end %>
            <span class="badge bg-warning"><%= review.rating %>/5</span>
            <p class="mb-0"><%= review.comment.truncate(100) %></p>
          </div>
        <% end %>
        <%= link_to "View All Reviews", reviews_path, class: "btn btn-info" %>
      </div>
    </div>
  </div>
</div>
