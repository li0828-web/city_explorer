<h1>All Reviews</h1>

<div class="row mb-4">
  <div class="col">
    <%= link_to "Back to Home", root_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="row">
  <div class="col">
    <% @reviews.each do |review| %>
      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title">
            <%= review.user_name %> 
            <span class="badge bg-warning"><%= review.rating %>/5</span>
          </h5>
          <h6 class="card-subtitle mb-2 text-muted">
            Reviewed: 
            <% if review.reviewable_type == "Restaurant" %>
              <%= link_to review.reviewable.name, restaurant_path(review.reviewable) %>
            <% else %>
              <%= link_to review.reviewable.name, landmark_path(review.reviewable) %>
            <% end %>
          </h6>
          <p class="card-text"><%= review.comment %></p>
          <p class="card-text">
            <small class="text-muted">Posted on <%= review.created_at.strftime("%B %d, %Y at %I:%M %p") %></small>
          </p>
          <%= button_to "Delete", review_path(review), method: :delete, class: "btn btn-danger btn-sm", 
                data: { confirm: "Are you sure?" } %>
        </div>
      </div>
    <% end %>
  </div>
</div>
