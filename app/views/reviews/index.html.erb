<h1 class="mb-4">All Reviews</h1>

<div class="row mb-4">
  <div class="col">
    <%= link_to "← Back to Home", root_path, class: "btn btn-secondary" %>
  </div>
</div>

<!-- Reviews Grid - Bootstrap Masonry-like layout -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
  <% @reviews.each do |review| %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <!-- Card header with rating -->
        <div class="card-header d-flex justify-content-between align-items-center">
          <strong><%= review.user_name %></strong>
          <span class="badge bg-warning"><%= review.rating %>/5</span>
        </div>
        
        <!-- Card body -->
        <div class="card-body">
          <h6 class="card-subtitle mb-2 text-muted">
            Reviewed: 
            <% if review.reviewable_type == "Restaurant" %>
              <%= link_to review.reviewable.name, restaurant_path(review.reviewable), class: "text-decoration-none" %>
            <% else %>
              <%= link_to review.reviewable.name, landmark_path(review.reviewable), class: "text-decoration-none" %>
            <% end %>
          </h6>
          
          <p class="card-text">
            "<%= review.comment %>"
          </p>
          
          <p class="card-text">
            <small class="text-muted">
              Posted on <%= review.created_at.strftime("%B %d, %Y") %>
            </small>
          </p>
        </div>
        
        <!-- Card footer with delete button -->
        <div class="card-footer bg-transparent">
          <%= button_to "Delete Review", review_path(review), 
                method: :delete, 
                class: "btn btn-danger btn-sm w-100",
                data: { confirm: "Are you sure you want to delete this review?" } %>
        </div>
      </div>
    </div>
  <% end %>
</div>
