<h1><%= @restaurant.name %></h1>

<div class="row">
  <div class="col-md-8">
    <div class="card mb-4">
      <div class="card-header">
        <h3>Details</h3>
      </div>
      <div class="card-body">
        <p><strong>Cuisine:</strong> <%= @restaurant.cuisine %></p>
        <p><strong>Address:</strong> <%= @restaurant.address %></p>
        <p><strong>Price Range:</strong> <%= @restaurant.price_range %></p>
        <p><strong>Rating:</strong> 
          <% if @restaurant.rating %>
            <span class="badge bg-warning fs-6"><%= @restaurant.rating %> / 5</span>
            
            <!-- Feature 5.2: ERB Conditional Example -->
            <% if @restaurant.rating >= 4.5 %>
              <span class="badge bg-success ms-2">Excellent! ⭐⭐⭐⭐⭐</span>
            <% elsif @restaurant.rating >= 3.5 %>
              <span class="badge bg-info ms-2">Good! ⭐⭐⭐⭐</span>
            <% elsif @restaurant.rating >= 2.5 %>
              <span class="badge bg-warning ms-2">Average ⭐⭐⭐</span>
            <% else %>
              <span class="badge bg-danger ms-2">Needs improvement ⭐⭐</span>
            <% end %>
            
          <% else %>
            <span class="badge bg-secondary">Not rated yet</span>
          <% end %>
        </p>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3>Reviews (<%= @reviews.count %>)</h3>
      </div>
      <div class="card-body">
        <% if @reviews.any? %>
          <% @reviews.each do |review| %>
            <div class="mb-3 pb-3 border-bottom">
              <h5><%= review.user_name %> 
                <span class="badge bg-warning"><%= review.rating %>/5</span>
                
                <!-- Another conditional example -->
                <% if review.rating == 5 %>
                  <span class="badge bg-success">Loved it! ❤️</span>
                <% elsif review.rating <= 2 %>
                  <span class="badge bg-danger">Disappointed 😞</span>
                <% end %>
              </h5>
              <p><%= review.comment %></p>
              <small class="text-muted">Posted on <%= review.created_at.strftime("%B %d, %Y") %></small>
            </div>
          <% end %>
        <% else %>
          <div class="alert alert-info">
            No reviews yet. Be the first to review this restaurant!
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mt-4">
  <%= link_to "Back to All Restaurants", restaurants_path, class: "btn btn-secondary" %>
  <%= link_to "Home", root_path, class: "btn btn-outline-secondary" %>
</div>
